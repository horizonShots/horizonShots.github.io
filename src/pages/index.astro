---
import Layout from '../layouts/Layout.astro';
import { BentoGrid } from '../components/BentoGrid';
import { ScrollyTelling } from '../components/ScrollyTelling';
---

<Layout title="horizonShots">
	<main class="min-h-screen relative z-10 pb-20">
        {/* Hero Header */}
        <header className="pt-20 pb-12 text-center">
            <h1 class="text-6xl md:text-8xl font-display font-bold text-white mb-4 text-glow">
                HORIZON<span class="text-acid">SHOTS</span>
            </h1>
            <p class="font-mono text-cyan text-lg tracking-widest">
                NOCTURNAL AUTOMOTIVE HUD
            </p>
        </header>

        {/* Main Grid */}
        <BentoGrid client:load />

        {/* Scrolly Telling Section */}
        <ScrollyTelling client:visible />
        
	</main>
</Layout>
